<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title><%= titulo || "Admin" %></title>

  <!-- Dynamic per-view CSS -->
  <% if (typeof cssFiles !== 'undefined' && Array.isArray(cssFiles)) { %>
  <% cssFiles.forEach(function(css) { %>
    <link rel="stylesheet" href="/css/<%= css %>">
  <% }); %>
  <% } %>

</head>
<body>

<header class="admin-topbar">
  <div class="admin-topbar-inner">
    <h1 class="admin-logo">Meu Mundo — Admin</h1>

    <nav class="admin-nav">
      <a href="/admin">Painel</a>
      <a href="/admin/secoes">Seções</a>
      <a href="/admin/posts">Posts</a>
      <a href="/admin/afazeres">Afazeres</a>
      <a href="/admin/comentarios">💬 Comentários</a>
      <a href="/admin/logout">Sair</a>
    </nav>
  </div>
</header>

<main class="admin-container">
  <%- body %>
</main>

<script src="/js/admin-afazeres.js"></script>


</body>
</html>
