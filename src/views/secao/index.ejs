<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %></title>
  
  <link rel="stylesheet" href="/css/secao-index.css">
</head>
<body>
<section class="section-block reveal">
  <div class="section-container">
    <h2 class="section-title"><%= secao.nome %></h2>

    <div class="posts-grid">
      <% posts.forEach(post => { %>
        <a
          href="/<%= secao.slug %>/post/<%= post.id %>"
          class="post-card reveal"
        >
          <!-- Wrapper adicionado para segurar o zoom (overflow: hidden) -->
          <div class="post-card-img-wrapper">
            <div
              class="post-thumb"
              style="background-image:url('<%= post.imagem || "/img/default.jpg" %>')"
            ></div>
          </div>

          <div class="post-info">
            <h3><%= post.titulo %></h3>
            <p><%= post.descricao %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>
</body>
</html>
