<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Secoes</title>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-secoes-index.css">
</head>
<body>
<h2 class="admin-title">📂 Seções</h2>
<p class="admin-description">Gerencie as seções do site</p>

<div class="admin-action-bar">
  <span></span>
  <a href="/admin/secoes/nova" class="btn btn-primary">+ Nova Seção</a>
</div>

<div class="admin-section">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Ordem</th>
        <th>Nome</th>
        <th>Slug</th>
        <th>Status</th>
        <th>Ações</th>
      </tr>
    </thead>

    <tbody>
      <% secoes.forEach(secao => { %>
        <tr>
          <td><%= secao.ordem %></td>
          <td><strong><%= secao.nome %></strong></td>
          <td><%= secao.slug %></td>
          <td>
            <span style="color: var(--green); font-weight: bold">
              Ativa
            </span>
          </td>
          <td>
            <!-- 🔥 CONTAINER CORRETO -->
            <div class="admin-table-actions">
              <a
                href="/admin/secoes/<%= secao.id %>/editar"
                class="btn btn-primary"
              >
                Editar
              </a>

              <form
                action="/admin/secoes/<%= secao.id %>/excluir"
                method="POST"
                onsubmit="return confirm('Deseja excluir esta seção?')"
              >
                <button class="btn btn-danger">
                  Excluir
                </button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
</body>
</html>
