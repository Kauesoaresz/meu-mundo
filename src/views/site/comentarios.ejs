<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/site-comentarios.css">
 
</head>
<body>
<section class="comentarios-page">

  <header class="comentarios-header">
    <h1>💬 Comentários</h1>
    <p>Deixe sua opinião sobre o mundo, ideias, sugestões ou qualquer coisa 😊</p>
  </header>

  <% if (enviado) { %>
  <div class="aviso-comentario">
    ✅ Comentário enviado com sucesso! <br>
    Ele será analisado pelo <strong>dono do mundo</strong> antes de aparecer publicamente 🌍
  </div>
<% } %>

  <!-- FORMULÁRIO -->
  <form method="POST" action="/comentarios" class="comentario-form">
    <div class="form-group">
      <label>Seu nome</label>
      <input
        type="text"
        name="nome"
        placeholder="Ex: Steve"
        required
      >
    </div>

    <div class="form-group">
      <label>Comentário</label>
      <textarea
        name="comentario"
        placeholder="Escreva seu comentário aqui..."
        required
      ></textarea>
    </div>

    <button type="submit">Enviar comentário</button>
  </form>

  <!-- LISTA -->
  <div class="comentarios-lista">

    <% if (comentarios.length === 0) { %>
      <p class="sem-comentarios">
        Ainda não há comentários. Seja o primeiro a comentar 👀
      </p>
    <% } %>

    <% comentarios.forEach(c => { %>
      <div class="comentario-card">
        <div class="comentario-topo">
          <strong><%= c.nome %></strong>
          <span>
            <%= new Date(c.created_at).toLocaleDateString("pt-BR") %>
          </span>
        </div>

        <p class="comentario-texto">
          <%= c.comentario %>
        </p>
      </div>
    <% }) %>

  </div>

</section>
</body>
</html>
