<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Secoes</title>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-secoes-index.css">
</head>
<body>
<div class="admin-page-wrapper">
  
  <header class="dashboard-header reveal-1">
    <h2 class="admin-title">📂 Gerenciar Seções</h2>
    <p class="admin-description">Organize as categorias do seu mundo e defina a ordem em que aparecem no menu.</p>
  </header>

  <!-- BARRA DE AÇÃO RÁPIDA -->
  <div class="admin-action-bar reveal-2">
    <div class="action-stats">
      Seções cadastradas: <strong><%= secoes.length %></strong>
    </div>
    <a href="/admin/secoes/nova" class="btn-new-section">
      <span>+</span> Nova Seção
    </a>
  </div>

  <!-- TABELA DE SEÇÕES (ESTILO CARDS) -->
  <div class="admin-table-container reveal-3">
    <% if (secoes.length === 0) { %>
      <div class="empty-state">
        <span class="empty-icon">📂</span>
        <p>Nenhuma seção criada. Crie uma para começar a organizar seus posts!</p>
      </div>
    <% } else { %>
      <table class="premium-table">
        <thead>
          <tr>
            <th>Ordem</th>
            <th>Nome</th>
            <th>Link (Slug)</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>

        <tbody>
          <% secoes.forEach(secao => { %>
            <tr class="<%= secao.ativa === false ? 'linha-inativa' : '' %>">
              
              <td class="col-ordem">
                <span class="ordem-badge"><%= secao.ordem %></span>
              </td>

              <td class="col-nome">
                <span class="icone-secao"><%= secao.icone || "📂" %></span>
                <strong><%= secao.nome %></strong>
              </td>

              <td class="col-slug">
                <span class="slug-text">/<%= secao.slug %></span>
              </td>

              <td class="col-status">
                <!-- Mostra o status real da seção -->
                <% if (secao.ativa !== false) { %>
                  <span class="badge badge-success">✅ Ativa</span>
                <% } else { %>
                  <span class="badge badge-muted">🚫 Inativa</span>
                <% } %>
              </td>

              <td class="col-acoes">
                <div class="action-buttons">
                  <a href="/admin/secoes/<%= secao.id %>/editar" class="btn-action btn-edit">Editar</a>
                  
                  <form
                    action="/admin/secoes/<%= secao.id %>/excluir"
                    method="POST"
                    onsubmit="return confirm('ATENÇÃO: Excluir uma seção pode afetar os posts vinculados a ela! Deseja continuar?')"
                  >
                    <button class="btn-action btn-delete">Excluir</button>
                  </form>
                </div>
              </td>

            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

</div>
</body>
</html>
