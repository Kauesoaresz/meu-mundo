<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %></title>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-mundo.css">
</head>
<body>
<h2 class="admin-title">🌍 Mundo</h2>
<p class="admin-description">
  Informações gerais e status do seu mundo Minecraft.
</p>

<form class="admin-form" method="POST" action="/admin/mundo">

  <!-- BLOCO: IDENTIDADE -->
  <div class="admin-section">
    <h3>Identidade</h3>

    <div class="admin-grid">
      <div>
        <label>Nome do Mundo</label>
        <input type="text" name="nome" value="<%= mundo.nome %>" required>
      </div>

      <div>
        <label>Versão do Minecraft</label>
        <input
          type="text"
          name="versao_minecraft"
          value="<%= mundo.versao_minecraft || "" %>"
        >
      </div>
    </div>

    <label>Descrição</label>
    <textarea name="descricao" rows="3"><%= mundo.descricao || "" %></textarea>
  </div>

  <!-- BLOCO: JOGO -->
  <div class="admin-section">
    <h3>Jogo</h3>

    <div class="admin-grid">
      <div>
        <label>Edição</label>
        <select name="edicao">
          <option value="Java Edition" <%= mundo.edicao === "Java Edition" ? "selected" : "" %>>
            Java Edition
          </option>
        </select>
      </div>

      <div>
        <label>Modo</label>
        <input type="text" name="modo" value="<%= mundo.modo || "" %>">
      </div>

      <div>
        <label>Dificuldade</label>
        <select name="dificuldade">
          <option value="Difícil" <%= mundo.dificuldade === "Difícil" ? "selected" : "" %>>Difícil</option>
          <option value="Normal" <%= mundo.dificuldade === "Normal" ? "selected" : "" %>>Normal</option>
          <option value="Fácil" <%= mundo.dificuldade === "Fácil" ? "selected" : "" %>>Fácil</option>
        </select>
      </div>

      <div>
        <label>Data de Criação</label>
        <input
          type="date"
          name="criado_em"
          value="<%= mundo.criado_em ? mundo.criado_em.toISOString().slice(0,10) : "" %>"
          required
        >
      </div>
    </div>
  </div>

  <!-- BLOCO: DIMENSÕES -->
  <div class="admin-section">
    <h3>Dimensões Ativas</h3>

    <div class="admin-checkboxes">
      <label>
        <input type="checkbox" name="overworld" <%= mundo.overworld ? "checked" : "" %>>
        Overworld
      </label>

      <label>
        <input type="checkbox" name="nether" <%= mundo.nether ? "checked" : "" %>>
        Nether
      </label>

      <label>
        <input type="checkbox" name="end" <%= mundo.end ? "checked" : "" %>>
        End
      </label>
    </div>
  </div>

  <!-- BLOCO: STATUS -->
  <div class="admin-section">
    <h3>Status Atual</h3>

    <label>🎯 Objetivo Atual</label>
    <textarea name="objetivo_atual" rows="3"><%= mundo.objetivo_atual || "" %></textarea>

    <label>🌱 Seed</label>
    <input type="text" name="seed" value="<%= mundo.seed || "" %>">

    <!-- 🔥 NOVOS CAMPOS -->
    <div class="admin-grid" style="margin-top: 1rem;">
      <div>
        <label>🎮 Última vez que jogou</label>
        <input
          type="date"
          name="ultima_jogatina"
          value="<%= mundo.ultima_jogatina
            ? mundo.ultima_jogatina.toISOString().slice(0,10)
            : "" %>"
        >
      </div>

      <div>
        <label>📅 Dia atual do mundo</label>
        <input
          type="number"
          name="dia_mundo"
          min="0"
          value="<%= mundo.dia_mundo || "" %>"
        >
      </div>
    </div>
  </div>

  <!-- AÇÕES -->
  <div class="admin-actions">
    <button type="submit" class="btn btn-primary">
      💾 Salvar Alterações
    </button>
  </div>

</form>
</body>
</html>
