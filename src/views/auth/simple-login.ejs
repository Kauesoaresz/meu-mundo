<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Acesso restrito</title>
  
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/auth-simple-login.css">
</head>
<body>

  <div class="login-box">
    <h2>Acesso restrito</h2>

    <form method="POST">
      <input
        type="password"
        name="senha"
        placeholder="Senha"
        required
      >
      <button type="submit">Entrar</button>
    </form>

    <div class="hint">
      Área administrativa
    </div>
  </div>

</body>
</html>
