<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Posts - Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-posts-index.css">
</head>
<body>
<div class="admin-page-wrapper">
  
  <header class="dashboard-header reveal-1">
    <h2 class="admin-title">📝 Gerenciar Posts</h2>
    <p class="admin-description">Visualize, edite e organize todas as construções e histórias do seu mundo.</p>
  </header>

  <!-- BARRA DE AÇÃO RÁPIDA -->
  <div class="admin-action-bar reveal-2">
    <div class="action-stats">
      Total de registros: <strong><%= posts.length %></strong>
    </div>
    <a href="/admin/posts/novo" class="btn-new-post">
      <span>+</span> Novo Post
    </a>
  </div>

  <!-- LISTA DE POSTS -->
  <div class="admin-post-list reveal-3">
    <% if (posts.length === 0) { %>
      <div class="empty-state">
        <span class="empty-icon">🧱</span>
        <p>Você ainda não criou nenhum post. Comece a documentar seu mundo!</p>
      </div>
    <% } else { %>
      
      <% posts.forEach(post => { %>
        <div class="admin-post-row">
          
          <!-- THUMBNAIL (CAPA) -->
          <div class="admin-post-thumb-wrapper">
            <% if (post.imagem) { %>
              <img src="<%= post.imagem %>" alt="<%= post.titulo %>" class="admin-post-thumb">
            <% } else { %>
              <div class="admin-post-thumb fallback">
                <span>Sem Capa</span>
              </div>
            <% } %>
          </div>

          <!-- INFORMAÇÕES DO POST -->
          <div class="admin-post-info">
            <strong><%= post.titulo %></strong>
            <div class="post-meta">
              <span class="meta-secao"><%= post.Secao.nome %></span>
              <span class="meta-data">📅 <%= new Date(post.criado_em).toLocaleDateString("pt-BR") %></span>
            </div>
          </div>

          <!-- STATUS -->
          <div class="admin-post-status">
            <span class="badge badge-success">● Publicado</span>
          </div>

          <!-- AÇÕES -->
          <div class="admin-post-actions">
            <a href="/admin/posts/<%= post.id %>/editar" class="btn-action btn-edit">Editar</a>
            
            <form 
              action="/admin/posts/<%= post.id %>/excluir" 
              method="POST" 
              onsubmit="return confirm('Tem certeza que deseja excluir permanentemente este post?')"
            >
              <button class="btn-action btn-delete">Excluir</button>
            </form>
          </div>

        </div>
      <% }) %>

    <% } %>
  </div>

</div>
</body>
</html>
