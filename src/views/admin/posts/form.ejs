<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post ? "Editar Post" : "Novo Post" %> - Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-posts-form.css">
</head>
<body>
<div class="admin-page-wrapper">

  <header class="dashboard-header reveal-1">
    <a href="/admin/posts" class="back-link">← Voltar para Posts</a>
    <h2 class="admin-title">
      <%= post ? "✏️ Editar Post" : "➕ Novo Post" %>
    </h2>
    <p class="admin-description">Preencha os detalhes da sua construção, história ou farm.</p>
  </header>

  <form
    class="admin-form"
    method="POST"
    enctype="multipart/form-data"
    action="<%= post ? `/admin/posts/${post.id}/editar` : '/admin/posts' %>"
  >

    <div class="split-layout">
      
      <!-- =========================
           COLUNA ESQUERDA — CONTEÚDO
      ========================== -->
      <div class="col-main reveal-2">
        
        <div class="form-section">
          <h3 class="section-badge">Conteúdo Principal</h3>

          <div class="form-group">
            <label>Título da Obra</label>
            <input
              type="text"
              name="titulo"
              placeholder="Ex: Castelo de Pedra"
              value="<%= post?.titulo || "" %>"
              required
            >
          </div>

          <div class="form-group">
            <label>Descrição Curta</label>
            <input
              type="text"
              name="descricao"
              placeholder="Um resumo do que é este post..."
              value="<%= post?.descricao || "" %>"
            >
          </div>

          <div class="form-group">
            <label>História / Conteúdo Completo</label>
            <textarea
              name="conteudo"
              rows="15"
              placeholder="Descreva os detalhes, como foi construído, lore..."
            ><%= post?.conteudo || "" %></textarea>
          </div>
        </div>

        <div class="form-section">
          <h3 class="section-badge">Mídia Externa</h3>
          <div class="form-group">
            <label>Vídeo do YouTube (ID ou Link)</label>
            <input
              type="text"
              name="video_youtube"
              placeholder="Ex: dQw4w9WgXcQ"
              value="<%= post?.video_youtube || "" %>"
            >
          </div>
        </div>

        <div class="form-section">
          <h3 class="section-badge">📍 Coordenadas</h3>
          
          <div class="coords-box">
            <div class="coords-inputs">
              <input type="number" name="coord_x" placeholder="X" value="<%= post?.coord_x || "" %>">
              <input type="number" name="coord_y" placeholder="Y" value="<%= post?.coord_y || "" %>">
              <input type="number" name="coord_z" placeholder="Z" value="<%= post?.coord_z || "" %>">
            </div>

            <select name="dimensao" class="dimensao-select">
              <option value="">Selecione a Dimensão</option>
              <option value="overworld" <%= post?.dimensao === "overworld" ? "selected" : "" %>>Overworld</option>
              <option value="nether" <%= post?.dimensao === "nether" ? "selected" : "" %>>Nether</option>
              <option value="end" <%= post?.dimensao === "end" ? "selected" : "" %>>End</option>
            </select>
          </div>
        </div>

      </div>

      <!-- =========================
           COLUNA DIREITA — CONTROLE
      ========================== -->
      <div class="col-sidebar reveal-3">
        
        <div class="form-section">
          <h3 class="section-badge">Organização</h3>
          <div class="form-group">
            <label>Seção (Categoria)</label>
            <select name="secao_id" required>
              <% secoes.forEach(secao => { %>
                <option
                  value="<%= secao.id %>"
                  <%= post?.secao_id === secao.id ? "selected" : "" %>
                >
                  <%= secao.nome %>
                </option>
              <% }) %>
            </select>
          </div>
        </div>

        <!-- IMAGEM DE CAPA -->
        <div class="form-section">
          <h3 class="section-badge">Imagem de Capa</h3>

          <div class="form-group">
            <label>URL Externa (Opcional)</label>
            <input
              type="text"
              name="imagem"
              id="imagemUrl"
              placeholder="https://..."
              value="<%= post?.imagem || "" %>"
            >
          </div>

          <div class="form-group">
            <label>Upload do Computador</label>
            <div class="file-upload-wrapper">
              <input
                type="file"
                name="imagem_upload"
                id="imagemUpload"
                accept="image/*"
                class="file-input"
              >
              <div class="file-upload-visual">
                <span>📁 Escolher Arquivo</span>
              </div>
            </div>
            <small class="helper-text">Upload tem prioridade sobre a URL</small>
          </div>

          <!-- PREVIEW DA CAPA -->
          <div id="previewCapa" class="image-preview-container">
            <% if (post?.imagem) { %>
              <img src="<%= post.imagem %>" alt="Capa atual">
            <% } %>
          </div>
        </div>

        <!-- GALERIA -->
        <div class="form-section">
          <h3 class="section-badge">Galeria</h3>

          <div class="form-group">
            <label>Adicionar Imagens</label>
            <div class="file-upload-wrapper">
              <input
                type="file"
                name="galeria"
                id="galeriaInput"
                accept="image/*"
                multiple
                class="file-input"
              >
              <div class="file-upload-visual">
                <span>📸 Selecionar Múltiplas</span>
              </div>
            </div>
          </div>

          <!-- PREVIEW DE NOVAS IMAGENS -->
          <div id="previewGaleria" class="gallery-preview-grid"></div>

          <!-- IMAGENS JÁ SALVAS NA GALERIA -->
          <% if (post?.imagens?.length) { %>
            <% const imgsGaleria = post.imagens.filter(img => img.imagem !== post.imagem); %>
            
            <% if (imgsGaleria.length > 0) { %>
              <div class="saved-gallery-divider">
                <span>Já salvas</span>
              </div>

              <div class="gallery-preview-grid">
                <% imgsGaleria.forEach(img => { %>
                  <div class="saved-image-card">
                    <img src="<%= img.imagem %>" alt="Imagem salva">
                    
                    <form
                      method="POST"
                      action="/admin/posts/imagem/<%= img.id %>/excluir"
                      onsubmit="return confirm('Excluir esta imagem permanentemente?')"
                      class="delete-img-form"
                    >
                      <button type="submit" class="btn-delete-img" title="Remover imagem">✕</button>
                    </form>
                  </div>
                <% }) %>
              </div>
            <% } %>
          <% } %>
        </div>

        <!-- AÇÕES -->
        <div class="form-section sticky-actions">
          <div class="admin-actions">
            <a href="/admin/posts" class="btn-cancel">Cancelar</a>
            <button type="submit" class="btn-save">💾 Salvar Post</button>
          </div>
        </div>

      </div>

    </div>
  </form>

</div>

<!-- SCRIPTS DE PREVIEW MANTIDOS E APERFEIÇOADOS -->
<script>
  // Preview imagem por URL
  const urlInput = document.getElementById("imagemUrl");
  const uploadInput = document.getElementById("imagemUpload");
  const preview = document.getElementById("previewCapa");

  if (urlInput) {
    urlInput.addEventListener("input", () => {
      if (urlInput.value && !uploadInput.files.length) {
        preview.innerHTML = `<img src="${urlInput.value}" alt="Preview URL">`;
      } else if (!urlInput.value && !uploadInput.files.length) {
        preview.innerHTML = ''; // Limpa se vazio
      }
    });
  }

  // Preview imagem por upload
  if (uploadInput) {
    uploadInput.addEventListener("change", () => {
      const file = uploadInput.files[0];
      if (file) {
        // Altera o texto visual do botão
        const visualText = uploadInput.nextElementSibling.querySelector('span');
        visualText.textContent = `✅ ${file.name.substring(0, 15)}...`;
        
        const reader = new FileReader();
        reader.onload = e => {
          preview.innerHTML = `<img src="${e.target.result}" alt="Preview Upload">`;
        };
        reader.readAsDataURL(file);
      }
    });
  }

  // Preview Galeria Múltipla
  const galeriaInput = document.getElementById("galeriaInput");
  const previewGaleria = document.getElementById("previewGaleria");

  if (galeriaInput) {
    galeriaInput.addEventListener("change", () => {
      previewGaleria.innerHTML = "";
      const files = Array.from(galeriaInput.files);
      
      if(files.length > 0) {
        const visualText = galeriaInput.nextElementSibling.querySelector('span');
        visualText.textContent = `✅ ${files.length} selecionadas`;
      }

      files.forEach(file => {
        const reader = new FileReader();
        reader.onload = e => {
          const div = document.createElement("div");
          div.className = "saved-image-card new-preview"; // Usa o mesmo estilo das salvas
          
          const img = document.createElement("img");
          img.src = e.target.result;
          
          div.appendChild(img);
          previewGaleria.appendChild(div);
        };
        reader.readAsDataURL(file);
      });
    });
  }
</script>
</body>
</html>
