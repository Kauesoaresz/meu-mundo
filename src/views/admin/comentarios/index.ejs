<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Comentários - Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-comentarios-index.css">
</head>
<body>
<div class="admin-page-wrapper">
  
  <header class="dashboard-header reveal-1">
    <h2 class="admin-title">💬 Moderação de Comentários</h2>
    <p class="admin-description">Aprove, oculte ou exclua as mensagens deixadas pelos visitantes no mural do seu mundo.</p>
  </header>

  <div class="admin-table-container reveal-2">
    <% if (comentarios.length === 0) { %>
      <div class="empty-state">
        <span class="empty-icon">📭</span>
        <p>Nenhum comentário encontrado no momento.</p>
      </div>
    <% } else { %>
      <table class="premium-table">
        <thead>
          <tr>
            <th>Autor</th>
            <th>Comentário</th>
            <th>Status</th>
            <th>Data</th>
            <th>Ações</th>
          </tr>
        </thead>
        
        <tbody>
          <% comentarios.forEach(c => { %>
            <!-- Adiciona uma classe específica se estiver pendente -->
            <tr class="<%= c.aprovado ? 'status-aprovado' : 'status-pendente' %>">
              
              <td class="col-autor">
                <strong><%= c.nome %></strong>
              </td>

              <td class="col-comentario">
                <div class="comentario-text" title="<%= c.comentario %>">
                  <%= c.comentario %>
                </div>
              </td>

              <td class="col-status">
                <% if (c.aprovado) { %>
                  <span class="badge badge-success">✅ Aprovado</span>
                <% } else { %>
                  <span class="badge badge-warning">⏳ Pendente</span>
                <% } %>
              </td>

              <td class="col-data">
                <%= new Date(c.created_at).toLocaleDateString("pt-BR") %>
              </td>

              <td class="col-acoes">
                <div class="action-buttons">
                  
                  <% if (!c.aprovado) { %>
                    <form method="POST" action="/admin/comentarios/<%= c.id %>/aprovar">
                      <button class="btn-action btn-approve">Aprovar</button>
                    </form>
                  <% } else { %>
                    <form method="POST" action="/admin/comentarios/<%= c.id %>/reprovar">
                      <button class="btn-action btn-reject">Ocultar</button>
                    </form>
                  <% } %>

                  <form method="POST" action="/admin/comentarios/<%= c.id %>/excluir"
                        onsubmit="return confirm('Tem certeza que deseja excluir permanentemente este comentário?')">
                    <button class="btn-action btn-delete">Excluir</button>
                  </form>
                  
                </div>
              </td>

            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

</div>
</body>
</html>
