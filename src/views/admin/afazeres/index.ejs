<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Afazeres</title>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-afazeres.css">
</head>
<body>
<div class="admin-afazeres-header">
  <h2>📋 Afazeres</h2>

  <form method="POST" action="/admin/afazeres" class="admin-afazeres-form">
    <input type="text" name="titulo" placeholder="Novo afazer" required>
    <select name="prioridade">
      <option value="baixa">Baixa</option>
      <option value="media" selected>Média</option>
      <option value="alta">Alta</option>
    </select>
    <button class="btn btn-primary">Adicionar</button>
  </form>
</div>

<div class="admin-afazeres-list">

  <% afazeres.forEach(a => { %>
    <div class="admin-afazer-item <%= a.status === 'concluido' ? 'concluido' : '' %>">

      <div class="admin-afazer-status <%= a.status %>">
        <%= a.status === "concluido"
          ? "Concluído"
          : a.status === "em_obra"
          ? "Em obra"
          : "Não iniciado" %>
      </div>

      <div class="admin-afazer-content">
        <strong><%= a.titulo %></strong>
        <% if (a.descricao) { %>
          <p><%= a.descricao %></p>
        <% } %>
      </div>

      <div class="admin-afazer-priority <%= a.prioridade %>">
        <%= a.prioridade.toUpperCase() %>
      </div>

      <div class="admin-afazer-actions">
        <select data-id="<%= a.id %>" class="status-select">
          <option value="nao_iniciado" <%= a.status==="nao_iniciado"?"selected":"" %>>Não iniciado</option>
          <option value="em_obra" <%= a.status==="em_obra"?"selected":"" %>>Em obra</option>
          <option value="concluido" <%= a.status==="concluido"?"selected":"" %>>Concluído</option>
        </select>
      </div>

      <a href="/admin/afazeres/<%= a.id %>/editar" class="btn btn-sm">
  Editar
</a>

    </div>
  <% }) %>
  
  

</div>
</body>
</html>
