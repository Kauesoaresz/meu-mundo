<link rel="stylesheet" href="/css/admin-encantamentos.css">

<div class="admin-encantamentos-container">
  <h1>📚 Gerenciar Encantamentos</h1>
  <p>Adicione, remova e marque os encantamentos que você já conseguiu no mundo.</p>

  <form action="/admin/encantamentos/add" method="POST" class="encantamento-form-card">
    <div class="form-group">
      <label for="nome">Nome do Encantamento</label>
      <input type="text" id="nome" name="nome" placeholder="Ex: Inquebrável" required>
    </div>

    <div class="form-group">
      <label for="categoria">Categoria</label>
      <select id="categoria" name="categoria" required>
        <option value="Armadura">🛡️ Armadura</option>
        <option value="Ferramentas">⛏️ Ferramentas</option>
        <option value="Armas">⚔️ Armas</option>
      </select>
    </div>

    <div class="form-group">
      <label for="nivel_maximo">Nível Máximo</label>
      <input type="number" id="nivel_maximo" name="nivel_maximo" min="1" max="5" value="1" required>
    </div>

    <div class="form-group">
      <label for="prioridade">Prioridade</label>
      <select id="prioridade" name="prioridade" required>
        <option value="baixa">Baixa</option>
        <option value="media" selected>Média</option>
        <option value="alta">Alta</option>
      </select>
    </div>

    <button type="submit" class="btn-add">➕ Adicionar</button>
  </form>

  <div class="encantamentos-grid">
    
    <div class="categoria-coluna">
      <h2>🛡️ Armadura</h2>
      <% if (armadura.length === 0) { %>
        <p style="text-align: center; color: #777;">Nenhum cadastrado.</p>
      <% } %>
      <% armadura.forEach(enc => { %>
        <div class="encantamento-card <%= enc.conquistado ? 'status-conquistado' : 'status-falta' %>">
          <div class="encantamento-info">
  <h3>
    <%= enc.nome %> 
    <%= enc.nivel_maximo > 1 ? ['I', 'II', 'III', 'IV', 'V'][enc.nivel_maximo - 1] : '' %>
  </h3>
  <span>Prioridade: <%= enc.prioridade.toUpperCase() %></span>
</div>
          <div class="encantamento-acoes">
            <form action="/admin/encantamentos/toggle/<%= enc.id %>" method="POST">
              <button type="submit" class="btn-toggle" title="Mudar Status">
                <%= enc.conquistado ? '✅' : '❌' %>
              </button>
            </form>
            <form action="/admin/encantamentos/delete/<%= enc.id %>" method="POST" onsubmit="return confirm('Apagar este encantamento?');">
              <button type="submit" class="btn-delete" title="Excluir">🗑️</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="categoria-coluna">
      <h2>⛏️ Ferramentas</h2>
      <% if (ferramentas.length === 0) { %>
        <p style="text-align: center; color: #777;">Nenhum cadastrado.</p>
      <% } %>
      <% ferramentas.forEach(enc => { %>
        <div class="encantamento-card <%= enc.conquistado ? 'status-conquistado' : 'status-falta' %>">
          <div class="encantamento-info">
  <h3>
    <%= enc.nome %> 
    <%= enc.nivel_maximo > 1 ? ['I', 'II', 'III', 'IV', 'V'][enc.nivel_maximo - 1] : '' %>
  </h3>
  <span>Prioridade: <%= enc.prioridade.toUpperCase() %></span>
</div>
          <div class="encantamento-acoes">
            <form action="/admin/encantamentos/toggle/<%= enc.id %>" method="POST">
              <button type="submit" class="btn-toggle">
                <%= enc.conquistado ? '✅' : '❌' %>
              </button>
            </form>
            <form action="/admin/encantamentos/delete/<%= enc.id %>" method="POST" onsubmit="return confirm('Apagar este encantamento?');">
              <button type="submit" class="btn-delete">🗑️</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="categoria-coluna">
      <h2>⚔️ Armas</h2>
      <% if (armas.length === 0) { %>
        <p style="text-align: center; color: #777;">Nenhum cadastrado.</p>
      <% } %>
      <% armas.forEach(enc => { %>
        <div class="encantamento-card <%= enc.conquistado ? 'status-conquistado' : 'status-falta' %>">
          <div class="encantamento-info">
  <h3>
    <%= enc.nome %> 
    <%= enc.nivel_maximo > 1 ? ['I', 'II', 'III', 'IV', 'V'][enc.nivel_maximo - 1] : '' %>
  </h3>
  <span>Prioridade: <%= enc.prioridade.toUpperCase() %></span>
</div>
          <div class="encantamento-acoes">
            <form action="/admin/encantamentos/toggle/<%= enc.id %>" method="POST">
              <button type="submit" class="btn-toggle">
                <%= enc.conquistado ? '✅' : '❌' %>
              </button>
            </form>
            <form action="/admin/encantamentos/delete/<%= enc.id %>" method="POST" onsubmit="return confirm('Apagar este encantamento?');">
              <button type="submit" class="btn-delete">🗑️</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

  </div>
</div>