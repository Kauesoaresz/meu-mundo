<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo || "Meu Mundo" %></title>

  <link rel="stylesheet" href="/css/base.css">

  <% if (typeof cssFiles !== 'undefined' && Array.isArray(cssFiles)) { %>
    <% cssFiles.forEach(function(css) { %>
      <link rel="stylesheet" href="/css/<%= css %>">
    <% }); %>
  <% } %>
</head>
<body>
  
  <header class="main-header">
    <div class="header-container">
      <a href="/" class="header-logo">
        <img src="/img/logo-icon.png" alt="" width="24" height="24" onerror="this.style.display='none'">
        <span>MEU MUNDO</span>
      </a>

      <nav class="header-nav">
        <a href="/" class="nav-link">Início</a>

        <% if (typeof secoes !== 'undefined' && secoes.length > 0) { %>
          <% secoes.forEach(secao => { %>
            <a href="/<%= secao.slug %>" class="nav-link"><%= secao.nome %></a>
          <% }) %>
        <% } %>

        <a href="/afazeres" class="nav-link">Afazeres</a>
        <a href="/encantamentos" class="nav-link">Encantamentos</a> 
        <a href="/comentarios" class="nav-link">Comentários</a>
        <a href="/arsenal" class="nav-link">Arsenal</a>
      </nav>
    </div>
  </header>

  <main>
    <%- body %>
  </main>

</body>
</html>