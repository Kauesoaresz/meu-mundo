<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= secao ? "Editar Seção" : "Nova Seção" %> - Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
  <link rel="stylesheet" href="/css/admin-secoes-form.css">
</head>
<body>
<h2 class="admin-title">
  <%= secao ? "✏️ Editar Seção" : "➕ Nova Seção" %>
</h2>

<div class="admin-card">
  <form
    class="admin-form"
    method="POST"
    action="<%= secao ? `/admin/secoes/${secao.id}/editar` : '/admin/secoes' %>"
  >

    <label>Nome da Seção</label>
    <input
      type="text"
      name="nome"
      value="<%= secao ? secao.nome : "" %>"
      required
    >

    <label>Slug</label>
    <input
      type="text"
      name="slug"
      value="<%= secao ? secao.slug : "" %>"
      required
    >

    <label>Ícone</label>
    <input
      type="text"
      name="icone"
      value="<%= secao ? secao.icone : "" %>"
      placeholder="🧱"
    >

    <label>Ordem (menu)</label>
    <input
      type="number"
      name="ordem"
      value="<%= secao ? secao.ordem : 0 %>"
      min="0"
    >

    <label>Status</label>
    <select name="ativa">
      <option value="1" <%= secao && secao.ativa ? "selected" : "" %>>
        Ativa
      </option>
      <option value="0" <%= secao && !secao.ativa ? "selected" : "" %>>
        Inativa
      </option>
    </select>

    <div class="admin-actions">
      <button type="submit" class="btn btn-primary">
        Salvar
      </button>

      <a href="/admin/secoes" class="btn">
        Cancelar
      </a>
    </div>

  </form>
</div>
</body>
</html>
